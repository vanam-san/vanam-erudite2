---
import AuthorCard from "@/components/AuthorCard.astro"
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getCollection } from "astro:content"

const authors = (await getCollection("authors")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
)
---

<Layout>
  <MetaPage slot="head" title="Authors" />
  <div class="page-header">
    <h1 class="page-title">Authors</h1>
  </div>
  <ul>
    {authors.map((author) => <AuthorCard author={author} />)}
  </ul>
</Layout>

<style>
  .page-header {
    margin-block-end: var(--space-m);
  }

  .page-title {
    font-size: var(--step-2);
    font-weight: var(--font-weight-medium);
    line-height: calc(var(--leading-offset) + 1em);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
</style>
