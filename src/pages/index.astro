---
import BlogCard from "@/components/BlogCard.astro"
import GalleryCard from "@/components/GalleryCard.astro"
import MetaPage from "@/components/MetaPage.astro"
import ScrollToTop from "@/components/ScrollToTop.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts, getRecentGalleries } from "@/lib/content"

const posts = await getPosts()
const recentPosts = posts.slice(0, 5)
const recentGalleries = await getRecentGalleries(4)
---

<Layout>
  <MetaPage slot="head" />
  <ScrollToTop floating />

  <section>
    <h2>Recent Posts</h2>
    <ul class="post-list">
      {recentPosts.map((post) => <BlogCard post={post} />)}
    </ul>
    <a href="/blog">View all posts &rarr;</a>
  </section>

  {recentGalleries.length > 0 && (
    <section>
      <h2>Recent Galleries</h2>
      <ul class="gallery-list">
        {recentGalleries.map((gallery) => (
          <GalleryCard gallery={gallery} />
        ))}
      </ul>
      <a href="/gallery">View all galleries &rarr;</a>
    </section>
  )}
</Layout>

<style>
  section {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    margin-block-end: var(--space-xl);
  }

  h2 {
    font-size: var(--step-1);
    font-weight: var(--font-weight-medium);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .gallery-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
  }

  @media (width < 40rem) {
    .gallery-list {
      grid-template-columns: 1fr;
    }
  }

  a {
    font-size: var(--step--1);
    color: var(--muted-foreground);
    transition: color 0.3s;

    &:hover {
      color: var(--foreground);
    }
  }
</style>
