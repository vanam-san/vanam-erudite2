---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout>
  <MetaPage slot="head" title="About Me" />
  <div class="page-header">
    <h1 class="page-title">About Me</h1>
  </div>
  <section>
    <div class="min-w-full">
      <div class="prose mb-8">
        <p class="mt-0">
          Welcome to your about page. This is a placeholder, customize this to
          content to tell visitors about yourself.
        </p>
        <p>
          You can edit this page by modifying
          <code class="bg-muted">src/pages/about.astro</code>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-block-end: var(--space-m);
  }

  .page-title {
    font-size: var(--step-2);
    font-weight: var(--font-weight-medium);
    line-height: calc(var(--leading-offset) + 1em);
  }
</style>
