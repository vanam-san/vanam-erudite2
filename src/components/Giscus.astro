---
import { GISCUS } from "@/consts"
---

<div
  id="giscus-container"
  class="mt-8"
  data-repo={GISCUS.repo}
  data-repo-id={GISCUS.repoId}
  data-category={GISCUS.category}
  data-category-id={GISCUS.categoryId}
>
  <div id="giscus-comments"></div>
</div>

<script>
  function loadGiscus() {
    const container = document.getElementById("giscus-container")
    if (!container) return

    const repo = container.getAttribute("data-repo")
    const repoId = container.getAttribute("data-repo-id")
    const category = container.getAttribute("data-category")
    const categoryId = container.getAttribute("data-category-id")

    if (!repo || !repoId || !categoryId) {
      console.warn(
        "[Giscus] Missing required config. Set PUBLIC_GISCUS_REPO, PUBLIC_GISCUS_REPO_ID, and PUBLIC_GISCUS_CATEGORY_ID environment variables.",
      )
      return
    }

    const existingScript = document.querySelector("script.giscus-script")
    if (existingScript) existingScript.remove()

    const existingIframe = container.querySelector("iframe.giscus-frame")
    if (existingIframe) existingIframe.remove()

    const currentTheme =
      document.documentElement.getAttribute("data-theme") ||
      localStorage.getItem("theme") ||
      (window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light")

    const script = document.createElement("script")
    script.src = "https://giscus.app/client.js"
    script.setAttribute("data-repo", repo)
    script.setAttribute("data-repo-id", repoId)
    script.setAttribute("data-category", category || "Comments")
    script.setAttribute("data-category-id", categoryId)
    script.setAttribute("data-mapping", "pathname")
    script.setAttribute("data-strict", "0")
    script.setAttribute("data-reactions-enabled", "1")
    script.setAttribute("data-emit-metadata", "0")
    script.setAttribute("data-input-position", "top")
    script.setAttribute("data-lang", "en")
    script.setAttribute("data-theme", currentTheme)
    script.crossOrigin = "anonymous"
    script.async = true
    script.classList.add("giscus-script")

    container.appendChild(script)
  }

  function syncGiscusTheme(theme: string) {
    const iframe = document.querySelector<HTMLIFrameElement>(
      "iframe.giscus-frame",
    )
    if (!iframe) return
    iframe.contentWindow?.postMessage(
      { giscus: { setConfig: { theme } } },
      "https://giscus.app",
    )
  }

  const themeObserver = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.attributeName === "data-theme") {
        const newTheme = document.documentElement.getAttribute("data-theme")
        if (newTheme) syncGiscusTheme(newTheme)
      }
    }
  })

  function startObserver() {
    themeObserver.disconnect()
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    })
  }

  document.addEventListener("astro:page-load", () => {
    loadGiscus()
    startObserver()
  })
  document.addEventListener("astro:after-swap", () => {
    loadGiscus()
    startObserver()
  })
</script>
