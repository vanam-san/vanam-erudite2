---
import { formatShortDate } from "@/lib/utils"
import { type CollectionEntry } from "astro:content"

type Props = { project: CollectionEntry<"projects"> }

const { project } = Astro.props
const { name, description, link, tags, startDate, endDate } = project.data
---

<li>
  <time datetime={startDate?.toISOString()}>
    {startDate ? formatShortDate(startDate) : "—"}
  </time>
  <a href={link} target="_blank" rel="noopener noreferrer">{name}</a>
  {tags && tags.length > 0 && (
    <entry-tags>{tags.join(" · ")}</entry-tags>
  )}
  {description && <entry-desc>{description}</entry-desc>}
</li>

<style>
  li {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    row-gap: var(--space-3xs);
    column-gap: var(--space-s);
    padding-block: var(--space-2xs);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 55%, transparent);

    &:last-child {
      border-bottom: none;
    }
  }

  time {
    grid-row: 1;
    grid-column: 1;
    font-size: var(--step--1);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--muted-foreground);
    white-space: nowrap;
  }

  a {
    grid-row: 1;
    grid-column: 2;
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    line-height: calc(var(--leading-offset) + 1em);
    color: inherit;
    transition: color 0.2s;

    &:hover {
      color: var(--primary);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  }

  entry-tags {
    grid-row: 2;
    grid-column: 1 / -1;
    font-size: var(--step--1);
    font-family: var(--font-mono);
    color: var(--muted-foreground);
  }

  entry-desc {
    grid-row: 3;
    grid-column: 1 / -1;
    font-size: var(--step--1);
    color: color-mix(in oklab, var(--muted-foreground) 70%, transparent);
    line-clamp: 1;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (width < 40rem) {
    li {
      grid-template-columns: 4rem 1fr;
    }
  }
</style>
