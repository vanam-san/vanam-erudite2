---
import { formatShortDate, getWordCount, getReadingTime } from "@/lib/utils"
import { type CollectionEntry } from "astro:content"

type Props = { post: CollectionEntry<"blog"> }

const { post } = Astro.props
const wordCount = getWordCount(post.body ?? "")
const readingTime = getReadingTime(wordCount)
const formattedWordCount =
  wordCount >= 1000 ? `${(wordCount / 1000).toFixed(1)}k` : String(wordCount)
---

<li>
  <time datetime={post.data.date.toISOString()}
    >{formatShortDate(post.data.date)}</time
  >
  <a href={`/blog/${post.id}`}>{post.data.title}</a>
  <entry-reading
    >{formattedWordCount}
    words · {readingTime} min read</entry-reading
  >
</li>

<style>
  li {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    align-items: baseline;
    column-gap: var(--space-s);
    padding-block: var(--space-2xs);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 55%, transparent);

    &:last-child {
      border-bottom: none;
    }
  }

  time {
    font-size: var(--step--1);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--muted-foreground);
    white-space: nowrap;
  }

  a {
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    line-height: calc(var(--leading-offset) + 1em);
    color: inherit;
    transition: color 0.2s;

    &:hover {
      color: var(--primary);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  }

  entry-reading {
    font-size: var(--step--1);
    color: var(--muted-foreground);
    white-space: nowrap;
  }

  @media (width < 40rem) {
    li {
      grid-template-columns: 4rem 1fr;
    }

    entry-reading {
      grid-column: 2;
      font-size: var(--step--2);
    }
  }
</style>
