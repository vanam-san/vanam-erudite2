---
import { formatDate, getWordCount, getReadingTime } from "@/lib/utils"
import { Image } from "astro:assets"
import { getEntries, type CollectionEntry } from "astro:content"

type Props = { post: CollectionEntry<"blog"> }

const { post } = Astro.props
const authors = await getEntries(post.data.authors)
const wordCount = getWordCount(post.body ?? "")
const readingTime = getReadingTime(wordCount)
---

<li>
  {post.data.image && (
      <a href={`/blog/${post.id}`} tabindex="-1" aria-hidden="true">
        <Image src={post.data.image} alt="" width={640} height={336} />
      </a>
    )}
  <entry-info>
    <a href={`/blog/${post.id}`}>{post.data.title}</a>
    <entry-meta>
      {authors.length > 0 && (
          <entry-authors>
            <author-avatars>
              {authors.map((author) => (
                <img
                  src={author.data.avatar}
                  alt={author.data.name}
                  width="18"
                  height="18"
                />
              ))}
            </author-avatars>
            <author-names>
              {authors.map((author, i) => (
                <>{i > 0 && ", "}{author.data.name}</>
              ))}
            </author-names>
          </entry-authors>
        )}
      <time datetime={post.data.date.toISOString()}
        >{formatDate(post.data.date)}</time
      >
      <entry-reading-time
        >{wordCount}
        words · {readingTime} min read</entry-reading-time
      >
      {post.data.tags && (
          <entry-tags>
            {post.data.tags.map((tag) => (
              <span>#{tag}</span>
            ))}
          </entry-tags>
        )}
    </entry-meta>
    <p>{post.data.description}</p>
  </entry-info>
</li>

<style>
  li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-s);
    padding: var(--space-s);
    border-radius: var(--radius-2xl);
    border: 1.5px solid var(--border);
    background-color: color-mix(in oklab, var(--muted) 20%, transparent);
    text-decoration-line: none;
    list-style: none;
    transition:
      border-color 0.3s,
      background-color 0.3s,
      box-shadow 0.3s,
      transform 0.3s;

    &:hover {
      border-color: var(--primary);
      background-color: color-mix(in oklab, var(--muted) 50%, transparent);
      box-shadow: 0 4px 24px color-mix(in oklab, var(--primary) 8%, transparent);
      transform: translateY(-2px);
    }

    > a {
      flex-shrink: 0;
      inline-size: 14rem;
      overflow: hidden;
      border-radius: var(--radius-xl);

      :global(img) {
        inline-size: 100%;
        block-size: auto;
        transition: transform 0.3s;
      }
    }

    &:hover > a :global(img) {
      transform: scale(1.05);
    }

    entry-info {
      display: flex;
      flex-direction: column;

      > a {
        font-size: var(--step-1);
        line-height: calc(var(--leading-offset) + 1em);
        font-weight: var(--font-weight-medium);
      }

      entry-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-3xs);
        margin-block-end: var(--space-3xs);
        font-size: var(--step--1);
        color: var(--muted-foreground);

        entry-authors {
          display: flex;
          align-items: center;
          gap: var(--space-3xs);

          author-avatars {
            display: flex;
            margin-block-end: -0.1em;

            img {
              border-radius: var(--radius-full);
              box-shadow: 0 0 0 1.5px var(--background);

              &:not(:first-child) {
                margin-inline-start: -0.375rem;
              }
            }
          }
        }

        entry-authors ~ time::before {
          content: "·";
          margin-inline-end: var(--space-3xs);
        }

        time ~ entry-reading-time::before {
          content: "·";
          margin-inline-end: var(--space-3xs);
        }

        entry-reading-time {
          white-space: nowrap;
        }

        entry-reading-time ~ entry-tags::before {
          content: "·";
        }

        entry-tags {
          display: flex;
          flex-wrap: wrap;
          gap: var(--space-3xs);

          span {
            color: color-mix(
              in oklab,
              var(--muted-foreground) 50%,
              transparent
            );
          }
        }

        time ~ entry-tags::before {
          content: "·";
        }
      }

      p {
        color: var(--muted-foreground);
      }
    }

    @media (width < 40rem) {
      flex-direction: column;

      > a {
        inline-size: 100%;
        max-inline-size: 32rem;
      }
    }
  }
</style>
