---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"

type Props = { gallery: CollectionEntry<"gallery"> }

const { gallery } = Astro.props
---

<li>
  <a href={`/gallery/${gallery.id}`}>
    <gallery-card-image>
      <Image
        src={gallery.data.cover}
        alt={gallery.data.title}
        width={640}
        height={336}
        loading="lazy"
      />
    </gallery-card-image>
    <gallery-card-info>
      <gallery-card-title>{gallery.data.title}</gallery-card-title>
      <gallery-card-desc>{gallery.data.description}</gallery-card-desc>
      <gallery-card-count>
        {gallery.data.photos.length}
        photo{gallery.data.photos.length === 1 ? "" : "s"}
      </gallery-card-count>
    </gallery-card-info>
  </a>
</li>

<style>
  li {
    list-style: none;
  }

  a {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-2xl);
    border: 1.5px solid var(--border);
    background-color: color-mix(in oklab, var(--muted) 20%, transparent);
    text-decoration-line: none;
    transition:
      border-color 0.3s,
      background-color 0.3s,
      box-shadow 0.3s,
      transform 0.3s;

    &:hover {
      border-color: var(--primary);
      background-color: color-mix(in oklab, var(--muted) 50%, transparent);
      box-shadow: 0 4px 24px color-mix(in oklab, var(--primary) 8%, transparent);
      transform: translateY(-2px);
    }
  }

  gallery-card-image {
    display: block;
    overflow: hidden;

    :global(img) {
      display: block;
      width: 100%;
      height: 12rem;
      object-fit: cover;
      transition: transform 0.3s;
    }
  }

  a:hover gallery-card-image :global(img) {
    transform: scale(1.05);
  }

  gallery-card-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-s);
  }

  gallery-card-title {
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    color: var(--foreground);
    line-height: calc(var(--leading-offset) + 1em);
  }

  gallery-card-desc {
    font-size: var(--step--1);
    color: var(--muted-foreground);
    line-clamp: 2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  gallery-card-count {
    font-size: 0.625rem;
    color: color-mix(in oklab, var(--muted-foreground) 70%, transparent);
  }
</style>
