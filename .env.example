# Umami Analytics
# Get your website ID from your Umami instance settings
PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
# Umami host domain - use your self-hosted domain (e.g., umami.yourdomain.com)
# Default: cloud.umami.is
PUBLIC_UMAMI_HOST=cloud.umami.is

# Giscus Comments
# Get values from https://giscus.app after enabling Discussions on your GitHub repo
PUBLIC_GISCUS_REPO=your-username/your-repo
PUBLIC_GISCUS_REPO_ID=your-repo-id
# Discussion category name (must match exactly what's set in your repo)
PUBLIC_GISCUS_CATEGORY=Comments
PUBLIC_GISCUS_CATEGORY_ID=your-category-id
